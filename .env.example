# Public archive runtime
NEXT_PUBLIC_SITE_ORIGIN=https://saroop.mereka.dev
ARCHIVE_PUBLIC_ORIGIN=https://saroop.mereka.dev

# Private Studio authentication
ARCHIVE_ADMIN_EMAILS=archive-owner@example.com
ARCHIVE_ADMIN_PASSWORD=replace-with-a-long-random-passphrase
ARCHIVE_SESSION_SECRET=replace-with-at-least-32-random-characters
ARCHIVE_SOURCE_HASH_SECRET=replace-with-a-separate-long-random-secret
ADMIN_API_TOKEN=replace-with-a-separate-long-automation-token
ARCHIVE_REVALIDATE_SECRET=replace-with-a-long-random-token

# Shared family workspace (the invite can rotate without changing workspace ID)
FAMILY_WORKSPACE_INVITE_SECRET=replace-with-a-long-random-family-link-secret
FAMILY_WORKSPACE_ID=replace-with-a-separate-stable-random-workspace-id
FAMILY_GENERATION_DAILY_NETWORK_LIMIT=12
FAMILY_GENERATION_DAILY_GLOBAL_LIMIT=100

# Public intake storage safeguards
CONTRIBUTION_DAILY_GLOBAL_LIMIT=500
MEMORY_DAILY_GLOBAL_LIMIT=1000

# AI providers used only after explicit consent and archive review
OPENAI_API_KEY=replace-with-the-archive-project-key
GEMINI_API_KEY=replace-with-the-archive-project-key
GEMINI_ANALYSIS_MODEL=gemini-3.1-flash-image
