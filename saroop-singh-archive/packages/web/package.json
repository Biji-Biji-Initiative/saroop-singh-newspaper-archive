{
  "name": "saroop-singh-archive",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0",
    "validate:content": "node scripts/validate-content.mjs",
    "prebuild": "npm run validate:content",
