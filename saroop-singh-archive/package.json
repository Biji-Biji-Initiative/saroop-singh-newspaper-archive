{
  "name": "@saroop-singh-archive/tooling",
  "version": "1.0.0",
  "description": "Convenience commands for the supported Saroop Singh Archive web application",
  "private": true,
  "scripts": {
    "start": "npm --prefix packages/web run start",
    "dev": "npm --prefix packages/web run dev",
    "build": "npm --prefix packages/web run build",
    "lint": "npm --prefix packages/web run lint",
    "type-check": "npm --prefix packages/web run type-check",
    "validate:content": "npm --prefix packages/web run validate:content",
    "verify:contributions": "npm --prefix packages/web run verify:gallery-submission-access"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Biji-Biji-Initiative/saroop-singh-newspaper-archive.git"
  },
  "keywords": [
    "historical-archive",
    "newspaper-digitization",
    "malayan-athletics",
    "monorepo"
  ]
}
